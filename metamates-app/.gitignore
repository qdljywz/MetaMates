# =============================================================================
# Metamates App — 开源仓库 .gitignore
# 说明：metamates-app/docs/OPEN_SOURCE.md
# =============================================================================

# --- 运行时 / 会话数据（用户本机，绝不入库）---
conversations.db
conversations.db.bak
conversations.sqlite
conversations.sqlite-wal
conversations.sqlite-shm
session-store.json

# --- 运行时 Inbox 剪藏（测试/用户产生，勿入库；保留空目录结构）---
**/Inbox/*
!**/Inbox/.gitkeep

# --- 依赖与构建产物（可 npm run build / electron:build 再生）---
node_modules/
dist/
dist-electron/
release/
release-build*/
release-fresh/
release-fresh2/
release-out/
release-startup/
release-startup2/
release-local*/
release2/
dist-release/
dist-release-*/
dist-release-new/
acp-poc/
poc/

# --- 环境变量与密钥 ---
.env
.env.local
.env.*.local
config/ai-config.json
config/*-api-key*.txt
config/api-keys/
*.pem
*.pfx
*.p12
.certificate

# --- 日志与崩溃 ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
crash.log
crash.dmp
codex-skill-scenario.log

# --- 测试 / 验证报告（CI 或本地再生）---
test-results/
playwright-report/
coverage/
*-report.json
acceptance-report.json
e2e-packaged-*.json
packaged-startup-probe.json
startup-audit/
startup-audit-summary.json
business-logic-report.json
overnight-verify*.json

# --- TypeScript / 编译锁 ---
*.tsbuildinfo
.electron-compile.lock

# --- IDE / OS ---
.vscode/
.idea/
.trae/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# --- 临时文件 ---
*.tmp
*.temp
*.bak
*.backup
*.orig

# --- 安装包产物（electron-builder 输出）---
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.blockmap

# --- E2E 临时工作区 ---
e2e/.workspace/
e2e-results.json

# --- 本地开发 Vault（勿入库）---
MyM2/

# --- 可选扩展（源码入库，依赖/模型/zip 不入库）---
plugins/**/node_modules/
plugins/**/models/
resources/models/
build/plugin-zips/
*.traineddata

# --- 迭代内部文档 ---
sprints/
docs/OVERNIGHT-RELEASE-REPORT.md

# --- Agent 记忆 / 本地备份 ---
.omc/
backups/

# --- Agent IDE 本地权限（机器相关，勿入库）---
**/.claude/settings.local.json
**/.codex/settings.local.json
**/settings.local.json

# --- 临时 HTML 测试页 ---
test-*.html

# --- CommonJS：默认忽略，显式保留构建/预加载/扩展入口 ---
*.cjs
!electron/preload.cjs
!scripts/compile-electron.cjs
!scripts/acp-quick-smoke.cjs
!plugins/**/*.cjs

# --- 保留示例配置 ---
!config/*.example.*
!.env.example
