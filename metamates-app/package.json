{
  "name": "metamates-app",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "description": "MetaMates - 本地 Electron 桌面知识库与 ACP Agent",
  "author": "MetaMates Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qdljywz/MetaMates.git"
  },
  "bugs": {
    "url": "https://github.com/qdljywz/MetaMates/issues"
  },
  "homepage": "https://github.com/qdljywz/MetaMates#readme",
  "scripts": {
    "dev": "vite",
    "start": "npm run electron:dev",
    "stop": "node scripts/stop-metamates.mjs",
    "check:opensource": "node scripts/check-open-source-hygiene.mjs",
    "logos:agents": "node scripts/generate-agent-logos.mjs",
    "logos:trace": "node scripts/extract-logo-trace.mjs",
    "verify:agent-logos": "node scripts/verify-agent-logos.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "node scripts/ensure-node-native.mjs && vitest run",
    "test:functional": "node scripts/full-functional-test.mjs --skip-build",
    "test:slash": "node scripts/verify-slash-commands.mjs",
    "generate:gemini-skills": "node scripts/generate-gemini-skills.mjs",
    "slash:e2e:ready": "node scripts/slash-e2e-checklist.mjs",
    "test:workspace-init": "node scripts/test-workspace-init.mjs",
    "test:slash:assembly": "node scripts/test-slash-prompt-assembly.mjs",
    "verify:agent": "node scripts/verify-agent-readiness.mjs",
    "verify:cli": "node scripts/verify-cli-alignment.mjs",
    "verify:stream": "node scripts/verify-acp-stream-pipeline.mjs",
    "verify:functional": "node scripts/verify-functional-acp.mjs",
    "verify:aion-parity": "node scripts/verify-aion-parity.mjs",
    "verify:business-logic": "node scripts/verify-business-logic.mjs",
    "verify:knowledge": "node scripts/verify-knowledge-features.mjs",
    "verify:acceptance": "npx tsc --noEmit && npm run verify:agent-logos && npm run verify:agent && npm run verify:knowledge && npm run test:slash",
    "test:ui": "npm run electron:compile && node scripts/full-functional-test.mjs --skip-build",
    "verify:round": "npx tsc --noEmit && npm run electron:compile && npm run test:run && npm run rebuild:native && node scripts/full-functional-test.mjs --skip-build",
    "verify:ci": "npm run verify:round && npm run test:e2e:full",
    "test:all": "npm run verify:round && npm run test:slash && npm run test:ux-guardrails && npm run test:e2e:full",
    "test:all:agent": "npm run test:all && npm run test:e2e:agent-live",
    "verify:overnight": "node scripts/overnight-verify.mjs",
    "clean:artifacts": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-build-artifacts.ps1",
    "clean:artifacts:reboot": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-build-artifacts.ps1 -ScheduleReboot",
    "clean:junk": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-dev-junk.ps1",
    "test:coverage": "vitest run --coverage",
    "test:dark-mode-audit": "node scripts/dark-mode-ui-audit.mjs",
    "test:full-manual-audit": "node scripts/full-manual-audit.mjs",
    "test:user-journey": "node scripts/user-journey-e2e.mjs",
    "test:voice-e2e": "node scripts/voice-e2e.mjs",
    "test:ux-latency": "node scripts/ux-latency-audit.mjs",
    "test:extended-coverage": "node scripts/extended-coverage-e2e.mjs",
    "test:slash-live-cli": "node scripts/slash-live-cli-e2e.mjs",
    "test:full-coverage": "node scripts/extended-coverage-e2e.mjs && node scripts/slash-live-cli-e2e.mjs",
    "test:e2e": "node scripts/playwright-e2e.mjs journey",
    "test:e2e:full": "node scripts/playwright-e2e.mjs full",
    "test:e2e:agent-live": "node scripts/playwright-e2e.mjs agent-live",
    "test:e2e:split": "node scripts/e2e-split.mjs",
    "test:e2e:legacy": "playwright test --ignore e2e/suite",
    "test:e2e:smoke": "node scripts/playwright-e2e.mjs journey",
    "test:e2e:journey": "node scripts/playwright-e2e.mjs journey",
    "test:e2e:ux-guardrails": "node scripts/playwright-e2e.mjs guardrails",
    "test:ux-guardrails": "vitest run src/test/startupUx.test.ts src/test/processTreeKill.test.ts src/test/fileTreeUx.test.ts src/test/editorEmptyState.test.ts src/test/emptyStatePlanner.test.ts src/utils/emptyStatePlanner.refresh.test.ts src/utils/emptyStateContextSignals.test.ts src/services/emptyStateBackgroundRethink.test.ts src/services/graduateInboxArchive.test.ts src/utils/openSlashWriteback.test.ts src/utils/tabClose.test.ts src/constants/paths.timezone.test.ts src/commands/slashWritePolicy.test.ts src/store/appStore.test.ts src/services/vaultPaths.test.ts src/utils/fileTreeExpand.test.ts",
    "test:e2e:editor": "node scripts/e2e-run-spec.mjs e2e/suite/03-editor.spec.ts",
    "test:e2e:editor-trust": "node scripts/e2e-run-spec.mjs e2e/suite/14-editor-trust.spec.ts",
    "test:e2e:timezone": "node scripts/e2e-run-spec.mjs e2e/suite/15-timezone-calendar.spec.ts",
    "test:e2e:vault-capture": "node scripts/e2e-run-spec.mjs e2e/suite/16-vault-capture.spec.ts",
    "test:e2e:agent-writeback": "node scripts/e2e-run-spec.mjs e2e/suite/17-agent-slash-writeback.spec.ts --agent-live",
    "test:e2e:graduate-live": "node scripts/e2e-run-spec.mjs e2e/suite/19-agent-graduate-live.spec.ts --agent-live",
    "test:e2e:no-cli": "node scripts/e2e-run-spec.mjs e2e/suite/18-startup-no-cli.spec.ts",
    "test:e2e:graph": "node scripts/e2e-run-spec.mjs e2e/suite/12-graph-interaction.spec.ts",
    "test:e2e:command-palette": "node scripts/e2e-run-spec.mjs e2e/suite/10-command-palette.spec.ts",
    "test:e2e:workspace-dirty": "node scripts/e2e-run-spec.mjs e2e/suite/20-workspace-dirty-guard.spec.ts",
    "verify:fresh-user": "node scripts/verify-fresh-packaged-user.mjs",
    "verify:inits-sync": "node scripts/verify-inits-sync.mjs",
    "sync:inits-to-app": "node scripts/sync-inits-to-app-bundled.mjs",
    "sync:inits-to-workspace": "node scripts/sync-inits-to-workspace.mjs",
    "test:e2e:debug": "playwright test --debug",
    "test:integration": "npm run electron:compile && node dist-electron/test-runner.js",
    "electron:dev": "concurrently -k \"vite\" \"npm run electron:compile && node scripts/ensure-electron-native.mjs && wait-on http://127.0.0.1:3000 && electron .\"",
    "postinstall": "node scripts/postinstall-native.mjs",
    "rebuild:native": "node scripts/ensure-electron-native.mjs",
    "rebuild:native:force": "npx @electron/rebuild -f -w better-sqlite3",
    "icons": "node scripts/generate-icons.mjs && npm run logos:agents",
    "electron:compile": "tsc -p tsconfig.node.json && node scripts/compile-electron.cjs",
    "electron:pack:check": "node scripts/verify-pack-prereqs.mjs && node scripts/verify-pack-lock.mjs && node scripts/verify-inits-sync.mjs",
    "electron:pack:verify-asar": "node scripts/verify-pack-asar.mjs",
    "electron:build": "npm run build && npm run electron:compile && npm run icons && npm run rebuild:native && npm run electron:pack:check && electron-builder --config electron-builder.yml && npm run electron:pack:verify-asar",
    "electron:build:win": "npm run electron:build -- --win --x64",
    "electron:build:mac": "npm run electron:build -- --mac",
    "electron:build:dir": "npm run electron:build -- --dir",
    "electron:build:linux": "npm run electron:build -- --linux"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.0.0",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/lang-markdown": "^6.5.0",
    "@playwright/test": "^1.58.2",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^6.3.2",
    "codemirror": "^6.0.2",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.20",
    "icon-gen": "^5.0.0",
    "jsdom": "^27.0.1",
    "marked": "^17.0.5",
    "path-browserify": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-resizable-panels": "^4.7.3",
    "react-window": "^2.2.7",
    "three": "^0.183.2",
    "typescript": "~5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.6.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  }
}
