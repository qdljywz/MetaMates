    "test:e2e:no-cli": "node scripts/e2e-run-spec.mjs e2e/suite/18-startup-no-cli.spec.ts",
    "test:e2e:graph": "node scripts/e2e-run-spec.mjs e2e/suite/12-graph-interaction.spec.ts",
    "test:e2e:command-palette": "node scripts/e2e-run-spec.mjs e2e/suite/10-command-palette.spec.ts",
