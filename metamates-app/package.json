    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^6.3.2",
    "codemirror": "^6.0.2",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.20",
    "icon-gen": "^5.0.0",
    "jsdom": "^27.0.1",
    "marked": "^17.0.5",
    "path-browserify": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-resizable-panels": "^4.7.3",
    "react-window": "^2.2.7",
    "three": "^0.183.2",
    "typescript": "~5.9.3",
