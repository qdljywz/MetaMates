    "electron:compile": "tsc -p tsconfig.node.json && node scripts/compile-electron.cjs",
    "electron:pack:check": "node scripts/verify-pack-prereqs.mjs && node scripts/verify-pack-lock.mjs && node scripts/verify-inits-sync.mjs && npm run verify:agent-logo-resolution && npm run verify:packaged-paths",
    "electron:pack:verify-asar": "node scripts/verify-pack-asar.mjs",
    "electron:build": "npm run icons && npm run build && npm run electron:compile && npm run rebuild:native && npm run electron:pack:check && electron-builder --config electron-builder.yml -c.directories.output=release && npm run electron:pack:verify-asar",
    "electron:build:win": "npm run electron:build -- --win --x64",
    "electron:build:mac": "npm run electron:build -- --mac",
    "electron:build:dir": "npm run electron:build -- --dir",
    "electron:build:win:portable": "npm run plugin:document-import:pack && npm run whisper:download-model && npm run plugin:offline-speech:pack && node scripts/verify-portable-pack-prereqs.mjs && npm run icons && npm run build && npm run electron:compile && npm run rebuild:native && npm run electron:pack:check && npx electron-builder --config electron-builder.yml --dir --win --x64 \"-c.directories.output=release/portable-green\" && npm run electron:pack:verify-asar",
    "patch:portable-dist": "node scripts/patch-packaged-asar-dist.mjs",
    "overnight:acceptance": "node scripts/overnight-acceptance.mjs",
    "pack:local-win": "npm run icons && npm run build && npm run electron:compile && npm run rebuild:native && npm run verify:agent-logo-resolution && electron-builder --config electron-builder.yml -c.directories.output=release --dir --win --x64",
    "electron:build:linux": "npm run electron:build -- --linux"
