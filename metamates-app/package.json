{
  "name": "metamates-app",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "description": "MetaMates — private inspiration vault + thinking engine (local Electron desktop)",
  "author": "MetaMates Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qdljywz/MetaMates.git"
  },
  "bugs": {
    "url": "https://github.com/qdljywz/MetaMates/issues"
  },
  "homepage": "https://github.com/qdljywz/MetaMates#readme",
  "scripts": {
    "dev": "vite",
    "start": "npm run electron:dev",
